@startuml PetTrackerApp
!theme plain
title 宠物记录应用 - 系统流程图

== 系统启动 ==

start
:应用启动;
:读取 localStorage;

if (有 currentUserId?) then (是)
  :获取用户信息;
  :加载宠物列表;
  :加载动态数据;
  :加载里程碑数据;
  :验证 currentPetId;
  :显示首页;
else (否)
  :跳转注册页面;
endif

stop

== 用户注册 ==

start
:进入注册页面;
:输入昵称;
:[可选]选择头像;
:点击确认注册;

:创建 User 对象;
:存储到 localStorage;
:设置 currentUserId;

:跳转首页;
:提示添加宠物;

stop

== 宠物管理 ==

start
:进入我的页面;

if (有宠物?) then (否)
  :显示空状态;
else (是)
  :显示资料卡列表;
endif

:点击添加/编辑;

:输入名称;
:选择种类;
:选择性别;
:设置生日;
:设置到家日期;
:[可选]上传头像;

:点击保存;
:创建 Pet 对象;
:存储到 localStorage;

:更新 store.pets;
:显示宠物资料卡;

stop

== 动态发布 ==

start
:进入记录页面;
:选择宠物筛选;

:输入文字内容;
:点击添加图片;
:选择图片(1-9张);

if (点击AI识别?) then (是)
  :上传图片到AI服务;
  :识别健康事件;
  :显示结果弹窗;
  :用户勾选事件;
  :点击确认归档;
  :创建里程碑记录;
endif

:点击发布;

:创建 Post 对象;
:存储到 localStorage;
:更新 store.posts;

:动态插入列表顶部;

stop

== 动态交互 ==

start
:查看动态列表;

--

:点击图片;
:显示图片预览;
:点击关闭;

--

:点击心形图标;

if (已点赞?) then (是)
  :心形变灰色;
  :移除点赞记录;
else (否)
  :心形变红色;
  :添加点赞记录;
endif

:更新本地状态(即时响应);
:更新 localStorage;
:显示点赞者名称;

--

:点击评论框;
:输入评论;
:点击发送;

:创建 Comment 对象;
:存储到 localStorage;
:更新 store.posts;

:评论显示在列表;

stop

== 大事年表 ==

start
:进入大事年表页面;

:选择宠物筛选;
:选择类型筛选;

:过滤里程碑数据;
note right
  - 检查 petId 是否有效
  - 按宠物/类型过滤
end note

:按日期倒序排序;
:AI事件优先;

:显示时间轴;

--

:点击"+"按钮;
:显示添加弹窗;

:选择事件类型;
:输入标题;
:输入描述;
:选择日期;

if (类型是体重?) then (是)
  :输入体重数值;
endif

:点击保存;

:创建 Milestone 对象;
:存储到 localStorage;
:更新 store.milestones;

:刷新时间轴显示;

stop

== AI看板 ==

start
:进入AI看板页面;

:获取当前宠物;

if (无宠物?) then (是)
  :显示空状态提示;
  stop
endif

:过滤该宠物里程碑;
:统计健康事件数;

if (事件数 < 2?) then (是)
  :显示引导提示;
  stop
endif

:生成健康报告;
partition "报告分析" {
  :计算健康评分;
  :分析体重趋势;
  :检查疫苗状态;
  :分析驱虫频率;
  :生成健康建议;
  :统计历史摘要;
}

:显示完整健康报告;

stop

== 用户切换 ==

start
:点击用户头像;
:显示用户列表;
:选择目标用户;

:设置新的 currentUserId;
:调用 loadData();

:加载新用户宠物;
:加载新用户动态;
:加载新用户里程碑;

:更新 store 状态;
:跳转首页;

stop

== 跨页面同步 ==

start
:选择宠物;
:调用 setCurrentPetId();

:更新 store.currentPetId;
:更新 localStorage;

fork
  :记录页面;
  :过滤该宠物动态;
fork again
  :大事年表;
  :过滤该宠物里程碑;
fork again
  :AI看板;
  :切换到该宠物报告;
end fork

:所有页面同步更新;

stop

@enduml
